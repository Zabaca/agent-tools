{
  "name": "git-clean-stop",
  "version": "0.1.0",
  "description": "Enforces a clean git status before Claude can stop. Uncommitted changes must be committed or ignored.",
  "author": { "name": "Zabaca" },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/check-git-clean.sh",
            "timeout": 10,
            "statusMessage": "Checking git status..."
          }
        ]
      }
    ]
  }
}
